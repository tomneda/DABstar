       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Save the audio output as an uncompressed PCM file.&lt;/p&gt;&lt;p&gt;Click to open a file selection dialog and save the PCM data.&lt;/p&gt;&lt;p&gt;The output is a standard &amp;quot;.wav&amp;quot; file compatible with most audio programs.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text"><string>Dump WAV</string></property>
