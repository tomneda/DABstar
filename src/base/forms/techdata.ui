   <!-- 5. Dump buttons (moved to bottom — infrequently used) -->
   <item>
    <layout class="QHBoxLayout" name="horizontalLayout_4">
     <item>
      <widget class="QPushButton" name="framedumpButton">
       <property name="toolTip">
        <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Audio services are encoded in MP2 or AAC format.&lt;/p&gt;&lt;p&gt;Click to open a file selection dialog and save the audio frames to a file.&lt;/p&gt;&lt;p&gt;Click again to close the output file. Programs such as VLC can play these files.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
       </property>
       <property name="text"><string>Dump AAC</string></property>
