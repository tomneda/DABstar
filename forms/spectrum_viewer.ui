         <item>
          <widget class="LevelMeter" name="thermoDigLevel" native="true">
           <property name="maximumSize">
            <size>
             <width>16777215</width>
             <height>30</height>
            </size>
           </property>
           <property name="toolTip">
            <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:600;&quot;&gt;RMS and peak Level in dBFS&lt;/span&gt;&lt;/p&gt;&lt;p&gt;The peak level is the maximum vector length of the input signal over 10 frames (approximately 1 second).&lt;/p&gt;&lt;p&gt;In digital systems it is generally recommended to keep the level slightly below 0 dBFS. However, since DAB uses phase modulation, some input overdrive may still yield acceptable results; the best approach is to maximise the Modulation Quality using the input gain.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
           </property>
           <property name="lowerBound" stdset="0">
            <double>-24.000000000000000</double>
           </property>
           <property name="upperBound" stdset="0">
            <double>4.000000000000000</double>
           </property>
          </widget>
