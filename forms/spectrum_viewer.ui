         <property name="toolTip">
          <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Correlation display.&lt;/p&gt;&lt;p&gt;Time synchronization is performed by correlation. The first peak above the threshold line corresponds to sample 504 (or nearby).&lt;/p&gt;&lt;p&gt;The signal is shown in dB, normalised to the threshold level.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Zooming&lt;/span&gt;&lt;br/&gt;Press &lt;span style=&quot; font-weight:700;&quot;&gt;&amp;lt;CTRL&amp;gt;&lt;/span&gt; key for &lt;span style=&quot; font-weight:700;&quot;&gt;vertical&lt;/span&gt; zooming, panning and reset zoom.&lt;br/&gt;Press &lt;span style=&quot; font-weight:700;&quot;&gt;&amp;lt;SHIFT&amp;gt;&lt;/span&gt; key for &lt;span style=&quot; font-weight:700;&quot;&gt;horizontal&lt;/span&gt; zooming, panning and reset zoom.&lt;br/&gt;Use mouse wheel for zooming.&lt;br/&gt;Press left mouse button for panning.&lt;br/&gt;Press right mouse button to reset zoom.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
         </property>
        </widget>
