      </item>
      <item>
       <widget class="QCheckBox" name="cbShowSLCurChOnly">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Filter the service list (main window) to show only the current ensemble&lt;/span&gt;&lt;/p&gt;&lt;p&gt;A convenience filter for a quicker overview of the available services.&lt;/p&gt;&lt;p&gt;This is activated automatically after &amp;quot;Add a single file to play&amp;quot;.&lt;/p&gt;&lt;p&gt;This setting is stored separately for channel and file playback.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>Show current ensemble in service list only</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Line" name="line_10">
        <property name="styleSheet">
