     <layout class="QHBoxLayout" name="horizontalLayout_4">
      <item>
       <widget class="QPushButton" name="btnResetDataBase">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Clear the current database&lt;/span&gt;&lt;/p&gt;&lt;p&gt;The channel list and the file list databases are stored separately.&lt;/p&gt;&lt;p&gt;Use this if you experience inconsistencies in the data (which should not normally occur).&lt;/p&gt;&lt;p&gt;Note: a large file list may take a long time to rescan afterwards.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>Reset database</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btnRemoveFilesWithoutSignal">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Remove entries detected as 'No signal' during scanning&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Removes file list entries that contain no valid sample data.&lt;/p&gt;&lt;p&gt;Activate the &amp;quot;No signal&amp;quot; filter to enable this button. Only the highlighted (reddish) rows will be removed.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>Remove 'No signals' files</string>
        </property>
       </widget>
      </item>
