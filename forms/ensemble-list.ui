   <item>
    <widget class="QWidget" name="containerFilePath" native="true">
     <layout class="QHBoxLayout" name="horLayoutFilePath">
      <item>
       <widget class="QPushButton" name="btnPathToScan">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Select the base folder for sample files&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Select the base folder containing one or more sample data files. The chosen path is shown to the right.&lt;/p&gt;&lt;p&gt;Use &amp;quot;Add files in folder to list&amp;quot; to add all files in the selected folder (and subfolders) to the ensemble list as &amp;quot;Not scanned&amp;quot; entries (greenish).&lt;/p&gt;&lt;p&gt;You can repeat this with a different base folder to add more files.&lt;/p&gt;&lt;p&gt;Invalid sample files are permitted; they will eventually be marked as &amp;quot;No signal&amp;quot;. File types are detected automatically.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>Folder with files to add</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLineEdit" name="ledPathToScan">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;The base folder for the files to add&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Use the &amp;quot;Folder with files to add&amp;quot; button to choose the folder, or type the path directly.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btnAddFilesInPath">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Add the files from the given base folder (left) to the ensemble list&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Add all files from the selected base folder to the ensemble list.&lt;/p&gt;&lt;p&gt;Only files of at least 4 MB are accepted. Use the spin box on the right to set a higher minimum file size to exclude files that are too short to be useful.&lt;/p&gt;&lt;p&gt;Files are added with the state &amp;quot;Not scanned&amp;quot; (greenish entries). You can repeat this with a different folder to add more files.&lt;/p&gt;&lt;p&gt;Invalid sample files are permitted; they will eventually be marked as &amp;quot;No signal&amp;quot;. File types are detected automatically.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>Add files in folder to list</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QSpinBox" name="spMinFileSizeMB">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Minimum file size in MB&lt;/span&gt;&lt;/p&gt;&lt;p&gt;Files smaller than 4 MB are always ignored.&lt;/p&gt;&lt;p&gt;Increase this value to exclude files with too short a playback duration.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="minimum">
         <number>4</number>
        </property>
        <property name="maximum">
         <number>9999</number>
        </property>
        <property name="stepType">
         <enum>QAbstractSpinBox::StepType::AdaptiveDecimalStepType</enum>
        </property>
        <property name="value">
         <number>100</number>
        </property>
       </widget>
      </item>
      <item>
       <widget class="Line" name="line">
        <property name="styleSheet">
         <string notr="true">background-color: #333333;</string>
        </property>
        <property name="orientation">
         <enum>Qt::Orientation::Vertical</enum>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btnAddSingleFile">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;&lt;span style=&quot; font-weight:700;&quot;&gt;Add a single file to the ensemble list and start it immediately&lt;/span&gt;&lt;/p&gt;&lt;p&gt;This replaces the former &amp;quot;Eject&amp;quot; button on the main window.&lt;/p&gt;&lt;p&gt;The chosen file is added to the ensemble list if not already present. If it already exists, it is selected and played immediately.&lt;/p&gt;&lt;p&gt;The minimum file size setting is ignored (only the absolute 4 MB minimum applies).&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="text">
         <string>Add a single file and play</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
